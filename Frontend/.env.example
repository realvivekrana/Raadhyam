# Vite environment variables must be prefixed with VITE_
# Copy this file to .env and fill in your values

# Backend API URL (used if you want to override the proxy)
# Default: proxied via vite.config.js to http://localhost:5000
VITE_API_URL=http://localhost:5000

# App name (optional, used in page titles)
VITE_APP_NAME=Raadhyam Music Portal
