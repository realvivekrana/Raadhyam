# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
**/node_modules/
.kilo
# ── Environment variables (NEVER commit secrets) ──────────────────────────────
.env
.env.local
.env.development
.env.production
.env.test
**/.env
**/.env.local
**/.env.development
**/.env.production
**/.env.test
